# Supabase-hosted PostgreSQL example for EduRecall.
# Copy this file to .env, replace every placeholder, and never commit .env.

NODE_ENV=development
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
API_PORT=4000
AI_SERVICE_URL=http://localhost:8001

# Public browser configuration. These values do not grant database write access;
# real protection must come from Auth/RLS or a server-side API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key

# Prisma uses DATABASE_URL for application/seed connections. Use a Supabase
# session-pooler or direct connection supported by your environment. URL-encode
# special characters in the database password.
DATABASE_URL="postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@SESSION_POOLER_HOST:5432/postgres?sslmode=require"

# Prisma consumes DIRECT_URL through datasource.directUrl for migration/schema
# operations. It must be a direct or session connection that supports DDL.
DIRECT_URL="postgresql://postgres:URL_ENCODED_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Replace these demo values before any shared or deployed environment.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

AI_PROVIDER=local-template
EXTERNAL_LLM_BASE_URL=https://mkp-api.fptcloud.com
EXTERNAL_LLM_MODEL=DeepSeek-V4-Flash
EXTERNAL_LLM_TIMEOUT_MS=60000
EXTERNAL_LLM_API_KEY=
TTS_BASE_URL=https://mkp-api.fptcloud.com
TTS_MODEL=FPT.AI-VITs
TTS_VOICE=std_kimngan
TTS_RESPONSE_FORMAT=wav
TTS_TIMEOUT_MS=90000
# Optional. If empty, TTS reuses EXTERNAL_LLM_API_KEY on the server.
TTS_API_KEY=
MAX_UPLOAD_MB=15

# This application currently uses Supabase only as hosted PostgreSQL through
# Prisma. It does not consume SUPABASE_URL, anon keys, Supabase Auth or Storage.
