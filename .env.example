NODE_ENV=development
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
API_PORT=4000
AI_SERVICE_URL=http://localhost:8001
DATABASE_URL=postgresql://edurecall:edurecall_dev@localhost:5432/edurecall?schema=public
# Prisma migrations use DIRECT_URL. For local PostgreSQL it can be the same
# direct connection as DATABASE_URL; hosted poolers usually require a distinct URL.
DIRECT_URL=postgresql://edurecall:edurecall_dev@localhost:5432/edurecall?schema=public
# Synthetic demo data is opt-in. Set true only when intentionally running db:seed.
ALLOW_SYNTHETIC_DEMO_SEED=false
ALLOW_LEGACY_DEMO_ADOPTION=false
DEMO_MODE=true
SYNTHETIC_DEMO_AS_OF=2026-07-18T12:00:00.000Z
DEMO_ACCOUNT_PASSWORD=Demo@123
POSTGRES_USER=edurecall
POSTGRES_PASSWORD=edurecall_dev
POSTGRES_DB=edurecall
JWT_ACCESS_SECRET=replace-in-production-access
JWT_REFRESH_SECRET=replace-in-production-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AI_PROVIDER=local-template
EXTERNAL_LLM_BASE_URL=https://mkp-api.fptcloud.com
EXTERNAL_LLM_MODEL=DeepSeek-V4-Flash
EXTERNAL_LLM_TIMEOUT_MS=60000
IDEA_GRADING_PROVIDER_TIMEOUT_MS=10000
EXTERNAL_LLM_API_KEY=
TTS_BASE_URL=https://mkp-api.fptcloud.com
TTS_MODEL=FPT.AI-VITs
TTS_VOICE=std_kimngan
TTS_RESPONSE_FORMAT=wav
TTS_TIMEOUT_MS=90000
# Optional. If empty, TTS reuses EXTERNAL_LLM_API_KEY on the server.
# EXTERNAL_TTS_API_KEY is accepted only as a legacy compatibility alias.
TTS_API_KEY=
